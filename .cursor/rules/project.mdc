# THE day-to-day command -- compile + link Sneeze only, no dep checks (seconds)
./scripts/build-linux.sh                       # Release (default)
./scripts/build-linux.sh --config Debug        # Debug
./scripts/build-macos.sh                       # macOS Release

# Reconfigure + build Sneeze only
./scripts/build-linux.sh --fresh
./scripts/build-macos.sh --fresh --config Debug

